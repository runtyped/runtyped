{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "target": "esnext",
    "module": "nodenext",
    "esModuleInterop": true,
    "declaration": true,
    "composite": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "moduleResolution": "nodenext"
  }
}

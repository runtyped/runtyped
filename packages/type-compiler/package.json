{
  "name": "@runtyped/type-compiler",
  "version": "1.0.20-alpha.5",
  "description": "@runtyped/type compiler/Typescript transformer",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "runtyped-compiler-debug": "./dist/compiler-debug.js",
    "runtyped-type-install": "./dist/install-transformer.js"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "install": "rm -rf node_modules/typescript && node ./runtyped-type-install.js || exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runtyped/runtyped.git"
  },
  "authors": [
    "Marc J. Schmidt <marc@marcjschmidt.de>",
    "Jacopo Scazzosi <jacopo@scazzosi.com>"
  ],
  "license": "MIT",
  "peerDependencies": {
    "typescript": "*"
  },
  "devDependencies": {
    "@runtyped/expect": "1.0.20-alpha.5",
    "@types/micromatch": "^4.0.10"
  },
  "dependencies": {
    "@runtyped/type-spec": "1.0.20-alpha.5",
    "@marcj/ts-clone-node": "^2.2.0",
    "@rollup/pluginutils": "^5.3.0",
    "@typescript/vfs": "1.6.4",
    "get-tsconfig": "^4.14.0",
    "lz-string": "^1.5.0",
    "micromatch": "^4.0.8",
    "strip-json-comments": "^5.0.3"
  },
  "keywords": ["validation", "reflection", "runtime", "types", "runtyped", "compiler", "transform", "typescript"]
}

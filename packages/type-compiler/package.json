{
  "name": "@runtyped/type-compiler",
  "version": "1.0.20-alpha.3",
  "description": "@runtyped/type compiler/Typescript transformer",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "bin": {
    "runtyped-compiler-debug": "deepkit-compiler-debug.js",
    "runtyped-type-install": "deepkit-type-install.js"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "install": "rm -rf node_modules/typescript && node ./deepkit-type-install.js || exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runtyped/runtyped.git"
  },
  "authors": [
    "Marc J. Schmidt <marc@marcjschmidt.de>",
    "Jacopo Scazzosi <jacopo@scazzosi.com>"
  ],
  "license": "MIT",
  "peerDependencies": {
    "typescript": "*"
  },
  "devDependencies": {
    "@runtyped/expect": "1.0.20-alpha.3",
    "@types/micromatch": "^4.0.10"
  },
  "dependencies": {
    "@runtyped/type-spec": "1.0.20-alpha.3",
    "@marcj/ts-clone-node": "^2.2.0",
    "@rollup/pluginutils": "^5.3.0",
    "@typescript/vfs": "1.6.4",
    "get-tsconfig": "^4.14.0",
    "lz-string": "^1.5.0",
    "micromatch": "^4.0.8",
    "strip-json-comments": "^5.0.3"
  }
}

{
  "name": "@runtyped/core",
  "version": "1.0.19",
  "description": "Runtyped core library",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": "https://github.com/runtyped/runtyped",
  "authors": [
    "Marc J. Schmidt <marc@marcjschmidt.de>",
    "Jacopo Scazzosi <jacopo@scazzosi.com>"
  ],
  "license": "MIT",
  "dependencies": {
    "dot-prop": "^10.1.0",
    "to-fast-properties": "^4.0.0"
  },
  "devDependencies": {
    "@runtyped/bench": "^1.0.19",
    "@runtyped/expect": "^1.0.19",
    "@types/dot-prop": "~5.0.4"
  },
  "scripts": {
    "build": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json"
  }
}
